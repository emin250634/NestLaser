<Window x:Class="NestLaserDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NestLaserDesktop.ViewModels"
        xmlns:views="clr-namespace:NestLaserDesktop.Views"
        Title="{Binding WindowTitle}" Height="820" Width="1280"
        MinHeight="700" MinWidth="1050"
        WindowStartupLocation="CenterScreen"
        Background="#151719"
        FontFamily="Segoe UI"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}" />
        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectAllCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}" />
    </Window.InputBindings>

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <views:IntToZeroConverter x:Key="IntToZeroConverter" />

        <SolidColorBrush x:Key="PanelBrush" Color="#202326" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#25292D" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="#181B1F" />
        <SolidColorBrush x:Key="BorderBrushDark" Color="#343A40" />
        <SolidColorBrush x:Key="TextBrush" Color="#D7DCE2" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8C97A3" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3FA7D6" />
        <SolidColorBrush x:Key="GreenBrush" Color="#4EC9B0" />
        <SolidColorBrush x:Key="DangerBrush" Color="#F05D5E" />

        <Style TargetType="Menu">
            <Setter Property="Background" Value="#1B1E22" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#1B1E22" />
            <Setter Property="Padding" Value="12,6" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#2B3036" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#3D454D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#35404A" />
                                <Setter Property="BorderBrush" Value="#4F8FB3" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1E6E93" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="74" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="ActiveToolbarButton" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Background" Value="#1E6E93" />
            <Setter Property="BorderBrush" Value="#6BBCE5" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#151719" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="#3D454D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushDark}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Background" Value="#1A1D21" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrushDark}"
                                BorderThickness="0,0,1,1">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource PanelBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#252B31" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MutedLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="BorderBrush" Value="#CCCCCC" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D0E8FF" />
                    <Setter Property="Foreground" Value="#000000" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#4EC9B0" />
                    <Setter Property="Foreground" Value="#000000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2B3036" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0">
            <MenuItem Header="_Dosya">
                <MenuItem Header="Yeni Proje" Command="{Binding NewProjectCommand}" />
                <MenuItem Header="Proje Aç" Command="{Binding OpenProjectCommand}" />
                <MenuItem Header="Projeyi Kaydet" Command="{Binding SaveProjectCommand}" />
                <MenuItem Header="Farklı Kaydet" Command="{Binding SaveProjectAsCommand}" />
                <MenuItem Header="Proje Paketi Dışa Aktar" Command="{Binding ExportProjectPackageCommand}" />
                <MenuItem Header="Proje Paketi İçe Aktar" Command="{Binding ImportProjectPackageCommand}" />
                <Separator />
                <MenuItem Header="DXF Aç" Command="{Binding OpenDxfCommand}" />
                <MenuItem Header="DXF Dışa Aktar" Command="{Binding ExportDxfCommand}" IsEnabled="{Binding CanExportDxf}" />
                <MenuItem Header="PDF Teklif Oluştur" Command="{Binding ExportQuotationPdfCommand}" />
                <MenuItem Header="PDF Üretim Raporu Oluştur" Command="{Binding ExportProductionPdfCommand}" />
                <Separator />
                <MenuItem Header="Son Kullanılanlar" ItemsSource="{Binding RecentProjects}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="Command" Value="{Binding DataContext.OpenRecentProjectCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="Çıkış" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="_Düzen">
                <MenuItem Header="Geri Al" Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z" />
                <MenuItem Header="İleri Al" Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y" />
                <Separator />
                <MenuItem Header="Sil" Command="{Binding DeleteSelectedCommand}" InputGestureText="Del" />
            </MenuItem>
            <MenuItem Header="_Görünüm">
                <MenuItem Header="Grid Göster" IsCheckable="True" IsChecked="{Binding ShowGrid, Mode=TwoWay}" />
                <MenuItem Header="Cetvel Göster" IsCheckable="True" IsChecked="{Binding ShowRulers, Mode=TwoWay}" />
                <Separator />
                <MenuItem Header="Parça İsmi Göster" IsCheckable="True" IsChecked="{Binding ShowPartNames, Mode=TwoWay}" />
                <MenuItem Header="Layer İsmi Göster" IsCheckable="True" IsChecked="{Binding ShowLayerNames, Mode=TwoWay}" />
                <MenuItem Header="Operasyon İsmi Göster" IsCheckable="True" IsChecked="{Binding ShowOperationNames, Mode=TwoWay}" />
                <Separator />
                <MenuItem Header="Grid 1 mm" Click="Grid1_Click" />
                <MenuItem Header="Grid 5 mm" Click="Grid5_Click" />
                <MenuItem Header="Grid 10 mm" Click="Grid10_Click" />
                <MenuItem Header="Grid 50 mm" Click="Grid50_Click" />
                <Separator />
                <MenuItem Header="Fit To Screen" Click="FitToScreen_Click" />
                <MenuItem Header="1:1 Görünüm" Click="ResetZoom_Click" />
            </MenuItem>
            <MenuItem Header="_Araçlar">
                <MenuItem Header="Yerleştir" Command="{Binding RunNestingCommand}" />
                <MenuItem Header="Benchmark Çalıştır" Command="{Binding RunBenchmarkCommand}" />
                <Separator />
                <MenuItem Header="Döndür 90°" Command="{Binding RotateSelected90Command}" />
                <MenuItem Header="Aynala X" Command="{Binding MirrorSelectedXCommand}" />
                <MenuItem Header="Aynala Y" Command="{Binding MirrorSelectedYCommand}" />
            </MenuItem>
            <MenuItem Header="_Yardım">
                <MenuItem Header="Hakkında" Click="About_Click" />
            </MenuItem>
        </Menu>

        <Border Grid.Row="1" Background="#20252A" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource ToolbarButton}" Content="Yeni" Command="{Binding NewProjectCommand}" ToolTip="Yeni Proje" />
                    <Button Style="{StaticResource ToolbarButton}" Content="Proje Aç" Command="{Binding OpenProjectCommand}" ToolTip="Proje Aç" />
                    <Button Style="{StaticResource ToolbarButton}" Content="Kaydet" Command="{Binding SaveProjectCommand}" ToolTip="Projeyi Kaydet" />
                    <Separator Width="10" Opacity="0" />
                    <Button Style="{StaticResource ToolbarButton}" Content="DXF Aç" Command="{Binding OpenDxfCommand}" ToolTip="DXF Aç" />
                    <Button Style="{StaticResource ToolbarButton}" Content="DXF Export" Command="{Binding ExportDxfCommand}" IsEnabled="{Binding CanExportDxf}" ToolTip="DXF Dışa Aktar" />
                    <Separator Width="10" Opacity="0" />
                    <Button Style="{StaticResource ToolbarButton}" Content="Geri Al" Command="{Binding UndoCommand}" ToolTip="Geri Al" />
                    <Button Style="{StaticResource ToolbarButton}" Content="İleri Al" Command="{Binding RedoCommand}" ToolTip="İleri Al" />
                    <Separator Width="10" Opacity="0" />
                    <Button x:Name="SelectToolButton" Style="{StaticResource ActiveToolbarButton}" Content="Seç" ToolTip="Seçim aracı" />
                    <Button x:Name="MeasureToolButton" Style="{StaticResource ToolbarButton}" Content="Ölç" Click="MeasureTool_Click" ToolTip="Mesafe Ölç" />
                    <Button Style="{StaticResource ToolbarButton}" Content="Döndür" Command="{Binding RotateSelected90Command}" ToolTip="Döndür 90°" />
                    <Button Style="{StaticResource ToolbarButton}" Content="Aynala X" Command="{Binding MirrorSelectedXCommand}" ToolTip="Aynala X" />
                    <Button Style="{StaticResource ToolbarButton}" Content="Aynala Y" Command="{Binding MirrorSelectedYCommand}" ToolTip="Aynala Y" />
                    <Button Style="{StaticResource ToolbarButton}" Content="Yerleştir" Command="{Binding RunNestingCommand}" ToolTip="Nesting çalıştır" />
                    <Button Style="{StaticResource ToolbarButton}" Content="Benchmark" Command="{Binding RunBenchmarkCommand}" ToolTip="Algoritma Karşılaştırma" />
                    <Button Style="{StaticResource ToolbarButton}" Content="Fit" Click="FitToScreen_Click" ToolTip="Fit To Screen" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <CheckBox Content="Grid" IsChecked="{Binding ShowGrid, Mode=TwoWay}" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11" />
                    <CheckBox Content="Ruler" IsChecked="{Binding ShowRulers, Mode=TwoWay}" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11" />
                    <CheckBox Content="İsim" IsChecked="{Binding ShowPartNames, Mode=TwoWay}" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11" />
                    <CheckBox Content="Layer" IsChecked="{Binding ShowLayerNames, Mode=TwoWay}" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11" />
                    <CheckBox Content="Op" IsChecked="{Binding ShowOperationNames, Mode=TwoWay}" Foreground="{StaticResource TextBrush}" Margin="0,0,8,0" VerticalAlignment="Center" FontSize="11" />
                    <TextBlock Text="Grid" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ComboBox Width="78" Height="28" SelectionChanged="GridStep_SelectionChanged" SelectedIndex="3"
                              Background="#151719" Foreground="{StaticResource TextBrush}">
                        <ComboBoxItem Content="1 mm" Tag="1" />
                        <ComboBoxItem Content="5 mm" Tag="5" />
                        <ComboBoxItem Content="10 mm" Tag="10" />
                        <ComboBoxItem Content="50 mm" Tag="50" />
                    </ComboBox>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="210" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#1B1F23" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,0,1" Padding="14,12">
                        <StackPanel>
                            <TextBlock Text="NestLaser Desktop" Foreground="{StaticResource AccentBrush}" FontSize="19" FontWeight="SemiBold" />
                            <TextBlock Text="Profesyonel CAD/CAM Workspace" Foreground="{StaticResource MutedTextBrush}" FontSize="11" Margin="0,3,0,0" />
                        </StackPanel>
                    </Border>

                    <TabControl>
                        <TabItem Header="Parçalar">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14">
                                    <!-- Dashboard Card -->
                                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Toplam Parça" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                                                <TextBlock Text="{Binding PartCount}" Foreground="{StaticResource GreenBrush}" FontSize="28" FontWeight="Bold" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Seçili" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                                                <TextBlock Text="{Binding SelectedCount}" Foreground="{StaticResource DangerBrush}" FontSize="28" FontWeight="Bold" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Toplam Alan" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                                                <TextBlock Text="{Binding TotalPartsAreaText}" Foreground="{StaticResource GreenBrush}" FontSize="16" FontWeight="Bold" />
                                            </StackPanel>

                                            <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="3" Margin="0,10,0,0" Visibility="{Binding HasNestResult, Converter={StaticResource BoolToVis}}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="#1A3A2A" CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding PlacedCount, StringFormat='{}Yerleşen: {0}'}" Foreground="{StaticResource GreenBrush}" FontSize="11" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Border Grid.Column="1" Background="#3A1A1A" CornerRadius="4" Padding="8,3" Margin="0,0,8,0" Visibility="{Binding UnplacedCount, Converter={StaticResource IntToZeroConverter}}">
                                                        <TextBlock Text="{Binding UnplacedCount, StringFormat='{}Sığmayan: {0}'}" Foreground="{StaticResource DangerBrush}" FontSize="11" FontWeight="SemiBold" />
                                                    </Border>
                                                    <Button Grid.Column="2" Content="Yeniden Yerleştir" Command="{Binding NestCommand}" Padding="10,3" FontSize="10" Background="#2A3A4A" BorderBrush="{StaticResource BorderBrushDark}" />
                                                </Grid>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- File Info (compact) -->
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Dosya:" Foreground="{StaticResource MutedTextBrush}" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding FilePathDisplay}" Foreground="{StaticResource TextBrush}" FontSize="10"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>

                                    <!-- Nesting Settings Panel -->
                                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,0,0,14">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Yerleştirme Ayarları" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" />
                                                <Button Grid.Column="1" Content="Yerleştirmeyi Başlat" Command="{Binding NestCommand}" Padding="14,6" FontSize="11" FontWeight="SemiBold"
                                                        Background="#1A4A3A" BorderBrush="{StaticResource GreenBrush}" HorizontalAlignment="Right" />
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Algoritma" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" />
                                                <ComboBox Grid.Column="1" ItemsSource="{Binding NestAlgorithms}"
                                                          SelectedItem="{Binding SelectedAlgorithm, Mode=TwoWay}"
                                                          Height="28" FontSize="11" Margin="10,0,0,0"
                                                          Background="#151719" Foreground="{StaticResource TextBrush}"
                                                          HorizontalAlignment="Stretch" MaxWidth="200" />
                                            </Grid>

                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Plaka Ölçüsü" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                                                    <TextBox Text="{Binding PlateWidthText, UpdateSourceTrigger=PropertyChanged}" Width="72" Height="26" FontSize="11" ToolTip="Genişlik (mm)" />
                                                    <TextBlock Text=" x " Foreground="{StaticResource MutedTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="4,0" />
                                                    <TextBox Text="{Binding PlateHeightText, UpdateSourceTrigger=PropertyChanged}" Width="72" Height="26" FontSize="11" ToolTip="Yükseklik (mm)" />
                                                    <TextBlock Text=" mm" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="4,0,0,0" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Boşluklar" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" />
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                                                    <TextBox Text="{Binding MarginText, UpdateSourceTrigger=PropertyChanged}" Width="72" Height="26" FontSize="11" ToolTip="Kenar Boşluğu (mm)" />
                                                    <TextBlock Text=" kenar" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="4,8,10,0" />
                                                    <TextBox Text="{Binding GapText, UpdateSourceTrigger=PropertyChanged}" Width="72" Height="26" FontSize="11" ToolTip="Parça Arası Boşluk (mm)" />
                                                    <TextBlock Text=" parça arası" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" Margin="4,8,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Part List -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Parça Listesi" Style="{StaticResource SectionTitle}" />
                                        <Button Grid.Column="1" Content="Seçileni Sil" Command="{Binding DeleteSelectedCommand}" Padding="10,2" FontSize="10" />
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="95" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding PartSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Parça ara" Margin="0,0,6,0" />
                                        <ComboBox Grid.Column="1" SelectedValue="{Binding PartSortMode, Mode=TwoWay}"
                                                  SelectedValuePath="Content" Height="28"
                                                  Background="#151719" Foreground="{StaticResource TextBrush}"
                                                  ToolTip="Sıralama">
                                            <ComboBoxItem Content="Ad" />
                                            <ComboBoxItem Content="Alan" />
                                            <ComboBoxItem Content="Genişlik" />
                                            <ComboBoxItem Content="Yükseklik" />
                                        </ComboBox>
                                    </Grid>
                                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Height="200">
                                        <ListBox x:Name="PartListBox"
                                                 ItemsSource="{Binding FilteredParts}"
                                                 SelectionChanged="PartListBox_SelectionChanged"
                                                 MouseDoubleClick="PartListBox_MouseDoubleClick"
                                                 Background="Transparent" Foreground="{StaticResource TextBrush}"
                                                 BorderThickness="0" FontSize="11"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="8" Height="8" CornerRadius="4" Margin="0,4,6,0" VerticalAlignment="Top">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="#555" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPlaced}" Value="True">
                                                                                <Setter Property="Background" Value="{StaticResource GreenBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                            </Border>
                                                            <StackPanel Grid.Column="1">
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#DCDCAA" />
                                                                <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="10">
                                                                    <Run Text="{Binding Width, Mode=OneWay, StringFormat={}{0:F1}}" />
                                                                    <Run Text="x" />
                                                                    <Run Text="{Binding Height, Mode=OneWay, StringFormat={}{0:F1}}" />
                                                                    <Run Text=" mm | " />
                                                                    <Run Text="{Binding Area, Mode=OneWay, StringFormat={}{0:F0}}" />
                                                                    <Run Text=" mm²" />
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Transform">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Seçim" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="{Binding SelectedPartInfo}" Foreground="{StaticResource TextBrush}" FontSize="11"
                                               TextWrapping="Wrap" Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Seçili Sayı" Style="{StaticResource MutedLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedCount}" Foreground="{StaticResource DangerBrush}" FontWeight="Bold" FontSize="12" />
                                    </Grid>

                                    <TextBlock Text="Transform" Style="{StaticResource SectionTitle}" />
                                    <UniformGrid Columns="2" Margin="0,0,0,12">
                                        <Button Content="Döndür 90°" Command="{Binding RotateSelected90Command}" Margin="0,0,5,8" />
                                        <Button Content="Sil" Command="{Binding DeleteSelectedCommand}" Margin="5,0,0,8" Background="#523034" BorderBrush="#80414A" />
                                        <Button Content="Aynala X" Command="{Binding MirrorSelectedXCommand}" Margin="0,0,5,8" />
                                        <Button Content="Aynala Y" Command="{Binding MirrorSelectedYCommand}" Margin="5,0,0,8" />
                                        <Button Content="Tümünü Seç" Command="{Binding SelectAllCommand}" Margin="0,0,5,0" />
                                        <Button Content="Seçimi Kaldır" Command="{Binding DeselectAllCommand}" Margin="5,0,0,0" />
                                    </UniformGrid>

                                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Ölçekleme" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6" />
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Çarpan" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" />
                                                <TextBox Grid.Column="1" Text="{Binding ScaleFactorText, UpdateSourceTrigger=PropertyChanged}" Margin="8,0,0,6" Height="26" FontSize="11" />
                                            </Grid>
                                            <UniformGrid Columns="2">
                                                <Button Content="Seçiliyi Büyüt" Command="{Binding ScaleSelectedCommand}" Margin="0,0,4,0" Padding="6,4" FontSize="10" />
                                                <Button Content="Tüm Parçaları Büyüt" Command="{Binding ScaleAllPartsCommand}" Margin="4,0,0,0" Padding="6,4" FontSize="10" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Properties">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Selection Bounds" Style="{StaticResource SectionTitle}" />
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Width" Style="{StaticResource MutedLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectionWidthText}" Foreground="{StaticResource GreenBrush}" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Height" Style="{StaticResource MutedLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectionHeightText}" Foreground="{StaticResource GreenBrush}" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Area" Style="{StaticResource MutedLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectionAreaText}" Foreground="{StaticResource GreenBrush}" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Perimeter" Style="{StaticResource MutedLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectionPerimeterText}" Foreground="{StaticResource GreenBrush}" FontWeight="Bold" />
                                    </Grid>
                                    <Grid Margin="0,0,0,14" Visibility="{Binding HasSelectedParts, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Total Area (Poly)" Style="{StaticResource MutedLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectionTotalAreaText}" Foreground="{StaticResource GreenBrush}" FontWeight="Bold" />
                                    </Grid>

                                    <TextBlock Text="Position" Style="{StaticResource SectionTitle}" />
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                            <TextBlock Text="X (mm)" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding PropertyXText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                            <TextBlock Text="Y (mm)" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding PropertyYText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="Size" Style="{StaticResource SectionTitle}" />
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                            <TextBlock Text="Width (mm)" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding PropertyWidthText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                            <TextBlock Text="Height (mm)" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding PropertyHeightText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>
                                    <CheckBox Content="Maintain Aspect Ratio" IsChecked="{Binding MaintainAspectRatio, Mode=TwoWay}"
                                              Foreground="{StaticResource TextBrush}" Margin="0,0,0,14" />

                                    <TextBlock Text="Rotation" Style="{StaticResource SectionTitle}" />
                                    <ComboBox IsEditable="True"
                                              Text="{Binding PropertyRotationText, UpdateSourceTrigger=PropertyChanged}"
                                              Background="#151719" Foreground="{StaticResource TextBrush}"
                                              Height="28" Margin="0,0,0,14">
                                        <ComboBoxItem Content="0" />
                                        <ComboBoxItem Content="45" />
                                        <ComboBoxItem Content="90" />
                                        <ComboBoxItem Content="180" />
                                        <ComboBoxItem Content="270" />
                                    </ComboBox>

                                    <Button Content="Apply" Command="{Binding ApplyPropertiesCommand}"
                                            Height="32" Background="#1E6E93" BorderBrush="#6BBCE5"
                                            ToolTip="Sayısal transform değerlerini uygula" />
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Katmanlar">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Lazer Katmanları" Style="{StaticResource SectionTitle}" />
                                        <Button Grid.Column="1" Content="Yeni" Command="{Binding AddLayerCommand}" Padding="8,2" Margin="0,0,6,0" />
                                        <Button Grid.Column="2" Content="Sil" Command="{Binding DeleteLayerCommand}" Padding="8,2" />
                                    </Grid>

                                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Height="230" Margin="0,0,0,12">
                                        <ListBox ItemsSource="{Binding Layers}"
                                                 SelectedItem="{Binding SelectedLayer, Mode=TwoWay}"
                                                 SelectionChanged="LayerList_SelectionChanged"
                                                 SelectionMode="Single"
                                                 Background="Transparent" Foreground="{StaticResource TextBrush}"
                                                 BorderThickness="0" FontSize="11">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="3" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="LayerItemBorder"
                                                                        Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="3">
                                                                    <ContentPresenter />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="LayerItemBorder" Property="Background" Value="#252B31" />
                                                                        <Setter TargetName="LayerItemBorder" Property="BorderBrush" Value="#3D454D" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="LayerItemBorder" Property="Background" Value="#1E3340" />
                                                                        <Setter TargetName="LayerItemBorder" Property="BorderBrush" Value="#3FA7D6" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8" Background="Transparent">
                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="20" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Width="14" Height="14" Background="{Binding Color}" BorderBrush="#808890" BorderThickness="1" CornerRadius="2" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" Foreground="#DCDCAA" Margin="6,0,8,0" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="2" Text="{Binding Type}" Foreground="#9CDCFE" FontFamily="Consolas" />
                                                            </Grid>
                                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,4,0,6">
                                                                <Run Text="Güç " />
                                                                <Run Text="{Binding Power, Mode=OneWay, StringFormat={}{0:F0}}" />
                                                                <Run Text=" | Hız " />
                                                                <Run Text="{Binding Speed, Mode=OneWay, StringFormat={}{0:F0}}" />
                                                                <Run Text=" | Pas " />
                                                                <Run Text="{Binding PassCount}" />
                                                            </TextBlock>
                                                            <UniformGrid Columns="2">
                                                                <Button Content="Görünür"
                                                                        Command="{Binding DataContext.ToggleLayerVisibilityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}" Padding="4,1" Margin="0,0,4,0"
                                                                        ToolTip="Katman görünürlüğünü aç/kapat" />
                                                                <Button Content="Kilit"
                                                                        Command="{Binding DataContext.ToggleLayerLockCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}" Padding="4,1" Margin="4,0,0,0"
                                                                        ToolTip="Katmanı kilitle/aç" />
                                                            </UniformGrid>
                                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,5,0,0" FontFamily="Consolas">
                                                                <Run Text="V: " />
                                                                <Run Text="{Binding IsVisible}" />
                                                                <Run Text=" | L: " />
                                                                <Run Text="{Binding IsLocked}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>

                                    <TextBlock Text="Katman Özellikleri" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="Ad" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding LayerNameText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="105" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                            <TextBlock Text="Tip" Style="{StaticResource MutedLabel}" />
                                            <ComboBox ItemsSource="{Binding LayerTypes}"
                                                      SelectedItem="{Binding SelectedLayerType, Mode=TwoWay}"
                                                      Background="#151719" Foreground="{StaticResource TextBrush}" Height="28" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Renk" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding LayerColorText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                            <TextBlock Text="Güç" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding LayerPowerText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                            <TextBlock Text="Hız" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding LayerSpeedText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="5,0,0,0">
                                            <TextBlock Text="Pas" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding LayerPassCountText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <UniformGrid Columns="2">
                                        <Button Content="Uygula" Command="{Binding ApplyLayerPropertiesCommand}"
                                                Margin="0,0,5,0" Background="#1E6E93" BorderBrush="#6BBCE5" />
                                        <Button Content="Seçiliyi Ata" Command="{Binding AssignSelectedToLayerCommand}"
                                                Margin="5,0,0,0" />
                                    </UniformGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Operasyonlar">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Üretim Operasyonları" Style="{StaticResource SectionTitle}" />
                                        <Button Grid.Column="1" Content="Yeni" Command="{Binding AddOperationCommand}" Padding="8,2" Margin="0,0,6,0" />
                                        <Button Grid.Column="2" Content="Sil" Command="{Binding DeleteOperationCommand}" Padding="8,2" />
                                    </Grid>

                                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Height="180" Margin="0,0,0,8">
                                        <ListBox ItemsSource="{Binding Operations}"
                                                 SelectedItem="{Binding SelectedOperation, Mode=TwoWay}"
                                                 SelectionMode="Single"
                                                 Background="Transparent" Foreground="{StaticResource TextBrush}"
                                                 BorderThickness="0" FontSize="11"
                                                 AllowDrop="True"
                                                 PreviewMouseLeftButtonDown="OperationList_PreviewMouseLeftButtonDown"
                                                 PreviewMouseMove="OperationList_PreviewMouseMove"
                                                 Drop="OperationList_Drop"
                                                 DragEnter="OperationList_DragEnter">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="3" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="OpItemBorder"
                                                                        Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="3">
                                                                    <ContentPresenter />
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="OpItemBorder" Property="Background" Value="#252B31" />
                                                                        <Setter TargetName="OpItemBorder" Property="BorderBrush" Value="#3D454D" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="OpItemBorder" Property="Background" Value="#1E3340" />
                                                                        <Setter TargetName="OpItemBorder" Property="BorderBrush" Value="#3FA7D6" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="8" Background="Transparent">
                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                                          Foreground="{StaticResource TextBrush}"
                                                                          VerticalAlignment="Center" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontWeight="SemiBold" Foreground="#DCDCAA" Margin="8,0,8,0" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Grid.Column="2" Text="{Binding Type}" Foreground="#9CDCFE" FontFamily="Consolas" />
                                                            </Grid>
                                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="10" Margin="0,4,0,0">
                                                                <Run Text="Öncelik " />
                                                                <Run Text="{Binding Priority, Mode=OneWay}" />
                                                                <Run Text="  |  Güç " />
                                                                <Run Text="{Binding Power, Mode=OneWay, StringFormat={}{0:F0}}" />
                                                                <Run Text="  |  Hız " />
                                                                <Run Text="{Binding Speed, Mode=OneWay, StringFormat={}{0:F0}}" />
                                                                <Run Text="  |  Pas " />
                                                                <Run Text="{Binding PassCount}" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Border>

                                    <UniformGrid Columns="3" Margin="0,0,0,10">
                                        <Button Content="▲ Yukarı" Command="{Binding MoveOperationUpCommand}" Margin="0,0,4,0" />
                                        <Button Content="▼ Aşağı" Command="{Binding MoveOperationDownCommand}" Margin="2,0" />
                                        <Button Content="⚡ Öner" Command="{Binding AutoSuggestOperationsCommand}" Margin="4,0,0,0" ToolTip="Katmanlara göre otomatik operasyon öner" />
                                    </UniformGrid>

                                    <TextBlock Text="Operasyon Özellikleri" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="Ad" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding OperationNameText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" />

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                            <TextBlock Text="Tip" Style="{StaticResource MutedLabel}" />
                                            <ComboBox ItemsSource="{Binding OperationTypes}"
                                                      SelectedItem="{Binding SelectedOperationType, Mode=TwoWay}"
                                                      Background="#151719" Foreground="{StaticResource TextBrush}" Height="28" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                            <TextBlock Text="Öncelik" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding OperationPriorityText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                            <TextBlock Text="Güç" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding OperationPowerText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                                            <TextBlock Text="Hız" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding OperationSpeedText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="5,0,0,0">
                                            <TextBlock Text="Pas" Style="{StaticResource MutedLabel}" />
                                            <TextBox Text="{Binding OperationPassCountText, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <UniformGrid Columns="3">
                                        <Button Content="Uygula" Command="{Binding ApplyOperationPropertiesCommand}"
                                                Margin="0,0,4,0" Background="#1E6E93" BorderBrush="#6BBCE5" />
                                        <Button Content="İç/Dış Analiz" Command="{Binding AnalyzeInnerOuterCommand}"
                                                Margin="2,0" ToolTip="İç kesim/dış kesim geometri analizi" />
                                        <CheckBox Content="Önizleme" IsChecked="{Binding OperationViewMode, Mode=TwoWay}"
                                                  Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" Margin="4,0,0,0" />
                                    </UniformGrid>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>

                        <TabItem Header="Malzemeler">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="14">
                                    <TextBlock Text="Malzeme ve Makine Profilleri" Style="{StaticResource SectionTitle}" />

                                    <TextBlock Text="Ara" Style="{StaticResource MutedLabel}" />
                                    <TextBox Text="{Binding MaterialFilterText, UpdateSourceTrigger=PropertyChanged}"
                                             Foreground="{StaticResource TextBrush}" Background="#1B1E22"
                                             BorderBrush="{StaticResource BorderBrushDark}" Padding="4" Margin="0,0,0,6" />

                                    <TextBlock Text="Seçili Malzeme" Style="{StaticResource MutedLabel}" />
                                    <ComboBox ItemsSource="{Binding FilteredMaterials}" SelectedItem="{Binding SelectedMaterial}"
                                              DisplayMemberPath="DisplayName"
                                              Foreground="White" Background="#2B3036"
                                              BorderBrush="{StaticResource BorderBrushDark}" Margin="0,0,0,4" />

                                    <UniformGrid Columns="3" Margin="0,0,0,10">
                                        <Button Content="Yeni" Command="{Binding AddMaterialCommand}" Margin="0,0,2,0" />
                                        <Button Content="Sil" Command="{Binding DeleteMaterialCommand}" Margin="2,0" />
                                        <Button Content="Yenile" Command="{Binding RefreshMaterialsCommand}" Margin="2,0,0,0" />
                                    </UniformGrid>

                                    <!-- Material Cost Fields -->
                                    <Border Background="#1E2A2A" BorderBrush="#4EC9B0" BorderThickness="1" Padding="8" Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Malzeme Maliyet Bilgileri" Foreground="#4EC9B0" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6" />
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                                    <TextBlock Text="Birim Fiyat" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                                                    <TextBox Text="{Binding SelectedMaterial.UnitPrice, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}" Foreground="White" Background="#1B1E22" BorderBrush="{StaticResource BorderBrushDark}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                                    <TextBlock Text="Birim Tipi" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                                                    <ComboBox ItemsSource="{Binding UnitTypeItems}" SelectedItem="{Binding SelectedMaterial.UnitType}"
                                                              Foreground="White" Background="#2B3036"
                                                              BorderBrush="{StaticResource BorderBrushDark}" Height="28" />
                                                </StackPanel>
                                            </Grid>
                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                                                    <TextBlock Text="Kalınlık (mm)" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                                                    <TextBox Text="{Binding SelectedMaterial.ThicknessMm, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}" Foreground="White" Background="#1B1E22" BorderBrush="{StaticResource BorderBrushDark}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                                    <TextBlock Text="Yoğunluk" Foreground="{StaticResource MutedTextBrush}" FontSize="10" />
                                                    <TextBox Text="{Binding SelectedMaterial.Density, UpdateSourceTrigger=PropertyChanged, TargetNullValue=0}" Foreground="White" Background="#1B1E22" BorderBrush="{StaticResource BorderBrushDark}" />
