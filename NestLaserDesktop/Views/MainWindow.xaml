                                </Border>

                                <TextBlock Text="Kısayollar" Style="{StaticResource SectionTitle}" Margin="0,0,0,6" />
                                <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" CornerRadius="6" Padding="12">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+Z" FontWeight="Bold" Foreground="#9CDCFE" FontFamily="Consolas" FontSize="11" Margin="0,0,16,4" />
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Geri Al" Foreground="{StaticResource TextBrush}" FontSize="11" Margin="0,0,0,4" />
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+Y" FontWeight="Bold" Foreground="#9CDCFE" FontFamily="Consolas" FontSize="11" Margin="0,0,16,4" />
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="İleri Al" Foreground="{StaticResource TextBrush}" FontSize="11" Margin="0,0,0,4" />
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Delete" FontWeight="Bold" Foreground="#9CDCFE" FontFamily="Consolas" FontSize="11" Margin="0,0,16,4" />
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="Seçili parçaları sil" Foreground="{StaticResource TextBrush}" FontSize="11" Margin="0,0,0,4" />
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="F" FontWeight="Bold" Foreground="#9CDCFE" FontFamily="Consolas" FontSize="11" Margin="0,0,16,4" />
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="Tuvali sığdır (Fit to Screen)" Foreground="{StaticResource TextBrush}" FontSize="11" Margin="0,0,0,4" />
                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Boşluk" FontWeight="Bold" Foreground="#9CDCFE" FontFamily="Consolas" FontSize="11" Margin="0,0,16,0" />
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="Pan (gezinti) modu" Foreground="{StaticResource TextBrush}" FontSize="11" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1" Background="#111417">
                <Grid.RowDefinitions>
                    <RowDefinition Height="24" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Background="#202326" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,0,1,1"
                        Visibility="{Binding ShowRulers, Converter={StaticResource BoolToVis}}" />
                <Canvas x:Name="HorizontalRulerCanvas" Grid.Row="0" Grid.Column="1" Background="#202326"
                        Visibility="{Binding ShowRulers, Converter={StaticResource BoolToVis}}" />
                <Canvas x:Name="VerticalRulerCanvas" Grid.Row="1" Grid.Column="0" Background="#202326"
                        Visibility="{Binding ShowRulers, Converter={StaticResource BoolToVis}}" />

                <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1">
                    <Grid>
                        <Canvas x:Name="NestCanvas" ClipToBounds="True"
                                SizeChanged="NestCanvas_SizeChanged"
                                MouseWheel="NestCanvas_MouseWheel"
                                MouseDown="NestCanvas_MouseDown"
                                MouseMove="NestCanvas_MouseMove"
                                MouseUp="NestCanvas_MouseUp"
                                MouseLeave="NestCanvas_MouseLeave"
                                Background="Transparent" />

                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                            <Button Content="Fit" Click="FitToScreen_Click" Width="54" Height="28" Padding="4,1"
                                    ToolTip="Sığdır (Fit to Screen)" />
                            <Button Content="1:1" Click="ResetZoom_Click" Width="54" Height="28" Padding="4,1" Margin="0,5,0,0"
                                    ToolTip="Gerçek boyut (100%)" />
                        </StackPanel>

                        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="#CC181B1F" BorderBrush="#343A40" BorderThickness="1"
                                Padding="18,14" CornerRadius="4"
                                Visibility="{Binding PartCount, Converter={StaticResource IntToZeroConverter}}">
                            <StackPanel>
                                <TextBlock Text="NestLaser Workspace" Foreground="{StaticResource TextBrush}"
                                           FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                <TextBlock Text="DXF açarak parçaları içe aktarın veya mevcut iş akışından devam edin."
                                           Foreground="{StaticResource MutedTextBrush}" FontSize="12"
                                           Margin="0,6,0,0" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,14,0,0"
                                Background="#E0202326" BorderBrush="#3FA7D6" BorderThickness="1"
                                Padding="14,8" CornerRadius="4"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                            <StackPanel Width="280">
                                <TextBlock Text="{Binding ProgressOverlayText}" Foreground="{StaticResource TextBrush}"
                                           FontSize="12" Margin="0,0,0,6" TextTrimming="CharacterEllipsis" />
                                <ProgressBar IsIndeterminate="{Binding IsProgressIndeterminate}"
                                             Value="{Binding ProgressPercent}"
                                             Minimum="0" Maximum="100" Height="4" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1,0,0,0" Padding="14">
                <StackPanel>
                    <TextBlock Text="Workspace" Style="{StaticResource SectionTitle}" />
                    <TextBlock Text="Grid" Style="{StaticResource MutedLabel}" />
                    <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13" FontFamily="Consolas" Margin="0,3,0,12">
                        <Run Text="{Binding GridStepMm, Mode=OneWay, StringFormat={}{0:F0}}" />
                        <Run Text=" mm" />
                    </TextBlock>

                    <TextBlock Text="Mouse" Style="{StaticResource MutedLabel}" />
                    <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13" FontFamily="Consolas" Margin="0,3,0,2">
                        <Run Text="X: " />
                        <Run Text="{Binding MouseXText, Mode=OneWay}" Foreground="#9CDCFE" />
                        <Run Text=" mm" />
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource TextBrush}" FontSize="13" FontFamily="Consolas" Margin="0,0,0,14">
                        <Run Text="Y: " />
                        <Run Text="{Binding MouseYText, Mode=OneWay}" Foreground="#9CDCFE" />
                        <Run Text=" mm" />
                    </TextBlock>

                    <Separator Background="{StaticResource BorderBrushDark}" Margin="0,0,0,12" />
                    <TextBlock Text="Katmanlar" Style="{StaticResource SectionTitle}" />
                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="10" Margin="0,0,0,14">
                        <TextBlock Text="Hazır alan" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                    </Border>

                    <TextBlock Text="Snap" Style="{StaticResource SectionTitle}" />
                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <CheckBox Content="Grid Snap" IsChecked="{Binding SnapToGrid, Mode=TwoWay}"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                            <CheckBox Content="Vertex Snap" IsChecked="{Binding SnapToVertex, Mode=TwoWay}"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                            <CheckBox Content="Edge Snap" IsChecked="{Binding SnapToEdge, Mode=TwoWay}"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />
                            <CheckBox Content="Center Snap" IsChecked="{Binding SnapToCenter, Mode=TwoWay}"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
                            <TextBlock Text="{Binding SnapStatusText}" Foreground="#FFD84D"
                                       FontFamily="Consolas" FontSize="11" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="DXF Export" Style="{StaticResource SectionTitle}" Margin="0,14,0,8" />
                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <CheckBox Content="Hidden layer export" IsChecked="{Binding ExportHiddenLayers, Mode=TwoWay}"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                            <CheckBox Content="Reference layer export" IsChecked="{Binding ExportReferenceLayer, Mode=TwoWay}"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                            <CheckBox Content="Selected only" IsChecked="{Binding ExportSelectedOnly, Mode=TwoWay}"
                                      Foreground="{StaticResource TextBrush}" Margin="0,0,0,6" />
                            <CheckBox Content="Plate border export" IsChecked="{Binding ExportPlateBorders, Mode=TwoWay}"
                                      Foreground="{StaticResource TextBrush}" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Kısayollar" Style="{StaticResource SectionTitle}" Margin="0,16,0,8" />
                    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="1" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Ctrl+A  Tümünü Seç" Foreground="{StaticResource MutedTextBrush}" FontFamily="Consolas" FontSize="11" Margin="0,0,0,4" />
                            <TextBlock Text="Delete  Sil" Foreground="{StaticResource MutedTextBrush}" FontFamily="Consolas" FontSize="11" Margin="0,0,0,4" />
                            <TextBlock Text="F       Fit" Foreground="{StaticResource MutedTextBrush}" FontFamily="Consolas" FontSize="11" Margin="0,0,0,4" />
                            <TextBlock Text="Space   Pan Mode" Foreground="{StaticResource MutedTextBrush}" FontFamily="Consolas" FontSize="11" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="#1B1E22" BorderBrush="{StaticResource BorderBrushDark}" BorderThickness="0,1,0,0" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Foreground="#DCDCAA" FontSize="11" TextTrimming="CharacterEllipsis">
                    <Run Text="{Binding StatusText, Mode=OneWay}" />
                    <Run Text="  |  Son İşlem: " Foreground="{StaticResource MutedTextBrush}" />
                    <Run Text="{Binding LastOperation, Mode=OneWay}" Foreground="#D7BA7D" />
                </TextBlock>

                <TextBlock Grid.Column="1" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontFamily="Consolas" Margin="20,0">
                    <Run Text="Zoom: " />
                    <Run Text="{Binding ZoomPercent, Mode=OneWay}" Foreground="{StaticResource TextBrush}" />
                    <Run Text="%  |  X: " />
                    <Run Text="{Binding MouseXText, Mode=OneWay}" Foreground="#9CDCFE" />
                    <Run Text=" mm  Y: " />
                    <Run Text="{Binding MouseYText, Mode=OneWay}" Foreground="#9CDCFE" />
                    <Run Text=" mm" />
                    <Run Text="  |  " />
                    <Run Text="{Binding SnapStatusText, Mode=OneWay}" Foreground="#FFD84D" />
                    <Run Text="  |  " />
                    <Run Text="{Binding ActiveToolText, Mode=OneWay}" Foreground="{StaticResource MutedTextBrush}" />
                </TextBlock>

                <TextBlock Grid.Column="2" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontFamily="Consolas">
                    <Run Text="Parça: " />
                    <Run Text="{Binding PartCount, Mode=OneWay}" Foreground="{StaticResource GreenBrush}" />
                    <Run Text="  |  Seçili: " />
                    <Run Text="{Binding SelectedCount, Mode=OneWay}" Foreground="{StaticResource DangerBrush}" />
                    <Run Text="  |  W: " />
                    <Run Text="{Binding SelectionWidthText, Mode=OneWay}" Foreground="{StaticResource GreenBrush}" />
                    <Run Text="  H: " />
                    <Run Text="{Binding SelectionHeightText, Mode=OneWay}" Foreground="{StaticResource GreenBrush}" />
                    <Run Text="  |  Süre: " />
                    <Run Text="{Binding NestingTimeText, Mode=OneWay}" Foreground="#9CDCFE" />
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
