<Window x:Class="NestLaserDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NestLaserDesktop.ViewModels"
        Title="NestLaser Desktop" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sol Panel -->
        <DockPanel Grid.Column="0" Background="#252526" Margin="0">
            <TextBlock DockPanel.Dock="Top" Text="NestLaser Desktop" Foreground="#569cd6"
                       FontSize="18" FontWeight="Bold" Margin="12,12,12,4" />
            <TextBlock DockPanel.Dock="Top" Text="Lazer Kesim Parça Yerleşimi" Foreground="#808080"
                       FontSize="11" Margin="12,0,12,10" />

            <StackPanel DockPanel.Dock="Bottom" Margin="12">
                <TextBlock Text="{Binding StatusText}" Foreground="#dcdcaa" FontSize="11"
                           TextWrapping="Wrap" Margin="0,0,0,8" />
                <Button Content="DXF Yükle" Click="OnLoadDxf" Height="30" Margin="0,0,0,6"
                        Background="#0e639c" Foreground="White" BorderThickness="0" />
                <Button Content="Nesting Çalıştır" Click="OnRunNesting" Height="30" Margin="0,0,0,6"
                        Background="#16825d" Foreground="White" BorderThickness="0" />
                <Button Content="DXF Dışa Aktar" Click="OnExportDxf" Height="30"
                        Background="#68217a" Foreground="White" BorderThickness="0" />
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12,8">
                    <!-- Plaka Ayarları -->
                    <TextBlock Text="Plaka Ayarları" Foreground="#569cd6" FontWeight="SemiBold" Margin="0,0,0,6" />

                    <TextBlock Text="Genişlik (mm)" Foreground="#cccccc" FontSize="11" />
                    <TextBox Text="{Binding PlateWidthText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"
                             Background="#3c3c3c" Foreground="white" BorderThickness="1" BorderBrush="#555" Padding="4,3" />

                    <TextBlock Text="Yükseklik (mm)" Foreground="#cccccc" FontSize="11" />
                    <TextBox Text="{Binding PlateHeightText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"
                             Background="#3c3c3c" Foreground="white" BorderThickness="1" BorderBrush="#555" Padding="4,3" />

                    <TextBlock Text="Kenar Boşluğu (mm)" Foreground="#cccccc" FontSize="11" />
                    <TextBox Text="{Binding MarginText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"
                             Background="#3c3c3c" Foreground="white" BorderThickness="1" BorderBrush="#555" Padding="4,3" />

                    <TextBlock Text="Parça Arası Boşluk (mm)" Foreground="#cccccc" FontSize="11" />
                    <TextBox Text="{Binding GapText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"
                             Background="#3c3c3c" Foreground="white" BorderThickness="1" BorderBrush="#555" Padding="4,3" />

                    <!-- Parça Bilgisi -->
                    <TextBlock Text="Parça Bilgisi" Foreground="#569cd6" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBlock Text="{Binding PartCount, StringFormat='Toplam: {0} parça'}" Foreground="#cccccc" FontSize="11" Margin="0,0,0,12" />

                    <!-- Sonuç -->
                    <TextBlock Text="Nesting Sonucu" Foreground="#569cd6" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Verimlilik:" Foreground="#cccccc" FontSize="11" />
                        <TextBlock Grid.Column="1" Text="{Binding EfficiencyText}" Foreground="#4ec9b0" FontWeight="Bold" FontSize="11" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Fire:" Foreground="#cccccc" FontSize="11" />
                        <TextBlock Grid.Column="1" Text="{Binding WasteText}" Foreground="#f44747" FontWeight="Bold" FontSize="11" />
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Yerleşemeyen:" Foreground="#cccccc" FontSize="11" />
                        <TextBlock Grid.Column="1" Text="{Binding UnplacedCount}" Foreground="#dcdcaa" FontWeight="Bold" FontSize="11" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Sağ: Önizleme -->
        <Grid Grid.Column="1" Margin="0">
            <Border Background="#1e1e1e" BorderBrush="#3c3c3c" BorderThickness="1">
                <Canvas x:Name="NestCanvas" ClipToBounds="True" />
            </Border>
            <TextBlock Text="DXF yüklendiğinde önizleme gösterilecek"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="#555" FontSize="13"
                       Visibility="{Binding PartCount, Converter={StaticResource IntToVisibilityConverter}}" />
        </Grid>
    </Grid>

    <Window.Resources>
        <local:IntToVisibilityConverter x:Key="IntToVisibilityConverter"
            xmlns:local="clr-namespace:NestLaserDesktop" />
    </Window.Resources>
</Window>
